menu "ESPClaw"

choice ESPCLAW_BOARD_PROFILE
    prompt "ESPClaw board profile"
    default ESPCLAW_BOARD_PROFILE_ESP32S3

config ESPCLAW_BOARD_PROFILE_ESP32S3
    bool "ESP32-S3"

config ESPCLAW_BOARD_PROFILE_ESP32CAM
    bool "ESP32-CAM"

config ESPCLAW_BOARD_PROFILE_ESP32C3
    bool "ESP32-C3"
endchoice

choice ESPCLAW_STORAGE_BACKEND
    prompt "ESPClaw workspace storage backend"
    default ESPCLAW_STORAGE_BACKEND_AUTO

config ESPCLAW_STORAGE_BACKEND_AUTO
    bool "Auto (use board profile default)"

config ESPCLAW_STORAGE_BACKEND_SD
    bool "SD card"

config ESPCLAW_STORAGE_BACKEND_LITTLEFS
    bool "LittleFS on internal flash"
endchoice

config ESPCLAW_ENABLE_SD_BOOTSTRAP
    bool "Enable SD mount and workspace bootstrap"
    default y

config ESPCLAW_SD_MOUNT_POINT
    string "SD mount point"
    default "/sdcard"

config ESPCLAW_SD_SPI_MOSI
    int "SDSPI MOSI pin"
    default -1

config ESPCLAW_SD_SPI_MISO
    int "SDSPI MISO pin"
    default -1

config ESPCLAW_SD_SPI_SCLK
    int "SDSPI SCLK pin"
    default -1

config ESPCLAW_SD_SPI_CS
    int "SDSPI CS pin"
    default -1

config ESPCLAW_FLASH_MOUNT_POINT
    string "Flash workspace mount point"
    default "/workspace"

config ESPCLAW_FLASH_PARTITION_LABEL
    string "Flash workspace partition label"
    default "workspace"

config ESPCLAW_ENABLE_WIFI_PROVISIONING
    bool "Enable Wi-Fi provisioning"
    default y

config ESPCLAW_ENABLE_TELEGRAM
    bool "Enable Telegram polling"
    default y

config ESPCLAW_TELEGRAM_BOT_TOKEN
    string "Telegram bot token"
    default ""

config ESPCLAW_TELEGRAM_POLL_INTERVAL_SECONDS
    int "Telegram poll interval"
    range 1 60
    default 5

endmenu
