CONFIG_ESPCLAW_BOARD_PROFILE_ESP32CAM=y
CONFIG_ESPCLAW_STORAGE_BACKEND_AUTO=y
CONFIG_SPIRAM=y
CONFIG_SPIRAM_BOOT_INIT=y
CONFIG_SPIRAM_USE_MALLOC=y
